    {"check_type": "are_complete", "level": "ROW", "category": "completeness", "description": "Checks that multiple fields have no null values", "engines": ["pandas", "pyspark", "polars", "duckdb", "dask", "bigquery"]},
    {"check_type": "is_unique", "level": "ROW", "category": "uniqueness", "description": "Checks that field values are unique", "engines": ["pandas", "pyspark", "polars", "duckdb", "dask", "bigquery"]},
    {"check_type": "are_unique", "level": "ROW", "category": "uniqueness", "description": "Checks that combination of fields is unique", "engines": ["pandas", "pyspark", "polars", "duckdb", "dask", "bigquery"]},
